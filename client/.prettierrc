{
  "arrowParens": "always",
  "endOfLine": "auto",
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "src/index.css",  
  "tailwindFunctions": ["cn", "cva"],
  "jsxSingleQuote": true
}
